import plotly.graph_objects as go
from plotly.subplots import make_subplots
import plotly.io as pio

# 1. Setup your subplots
fig = make_subplots(rows=1, cols=2)

# 2. Get the colorway from your active template
# If you haven't set a default, replace pio.templates.default with your template name
colors = pio.templates[pio.templates.default].layout.colorway

# 3. Add traces and manually assign colors from the list
fig.add_trace(
    go.Bar(y=[2, 3, 1], marker_color=colors[0]), # First color
    row=1, col=1
)

fig.add_trace(
    go.Bar(y=[4, 1, 6], marker_color=colors[1]), # Second color
    row=1, col=2
)

fig.show()


import pandas as pd
import plotly.express as px

# 1. Identify where the status changes
# We compare the current row to the next row
change_indices = df['status'] != df['status'].shift(-1)

# 2. Identify the rows immediately AFTER a change
# (This ensures we capture the first point of the new status)
after_change = df['status'] != df['status'].shift(1)

# 3. Combine them: Keep any row that is either a start or an end of a state
# We also keep the very first and very last rows to ensure the plot is complete
reduced_df = df[change_indices | after_change].copy()

# 4. Plotting
fig = px.line(reduced_df, x='timestamp', y='status', title="Digital Status (Optimized)")
# Ensure lines are 'HV' (Horizontal-Vertical) for extra safety, 
# though the data reduction above fixes the "slope" issue.
fig.update_traces(line_shape='hv') 
fig.show()
